{
  "projects": [
    {
      "project_id": "project-brain",
      "name": "Project-Brain",
      "repo_path": "~/code/Project-Brain",
      "remote_url": "git@github.com:example/Project-Brain.git",
      "default_branch": "main",
      "codex_command": [
        "codex",
        "exec",
        "--sandbox",
        "workspace-write",
        "-"
      ],
      "verification_commands": [
        {
          "id": "unit-tests",
          "text": "Project unit tests pass",
          "command": [
            "python",
            "-m",
            "unittest",
            "discover",
            "-s",
            "tests"
          ]
        }
      ],
      "allowed_commands": {
        "test": [
          "python",
          "-m",
          "unittest",
          "discover",
          "-s",
          "tests"
        ]
      },
      "auto_push": true,
      "auto_pr": true
    }
  ]
}
